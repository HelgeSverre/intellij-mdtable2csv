<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.helgesverre.mdtable2csv</id>
    <name>Markdown Table to CSV</name>
    <vendor email="helge.sverre@gmail.com" url="https://github.com/helgesverre">Helge Sverre</vendor>

    <description><![CDATA[
        Export Markdown tables to CSV without leaving the editor.
        <br/>
        Right-click inside a Markdown (GFM) table and convert it to CSV — open the result in a
        new editor tab or save it to a <code>.csv</code> file.
    ]]></description>

    <!-- Product and plugin compatibility: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Bundled Markdown support — gives us the Markdown PSI we read tables from. -->
    <depends>org.intellij.plugins.markdown</depends>

    <resource-bundle>messages.MdTable2CsvBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings -> Tools -> Markdown Table to CSV: the CSV delimiter preference. -->
        <applicationConfigurable
            parentId="tools"
            instance="com.helgesverre.mdtable2csv.settings.MdTable2CsvConfigurable"
            id="com.helgesverre.mdtable2csv.settings"
            displayName="Markdown Table to CSV"/>
        <!-- Balloon shown when a conversion finds no table content at the caret. -->
        <notificationGroup id="Markdown Table to CSV" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="com.helgesverre.mdtable2csv.TableToCsvGroup"
               class="com.helgesverre.mdtable2csv.actions.TableToCsvActionGroup"
               popup="true"
               text="Markdown Table to CSV"
               description="Convert the Markdown table under the caret to CSV">
            <action id="com.helgesverre.mdtable2csv.CopyTableAsCsv"
                    class="com.helgesverre.mdtable2csv.actions.CopyTableAsCsvAction"
                    text="Copy as CSV"
                    description="Copy this Markdown table to the clipboard as CSV"/>
            <action id="com.helgesverre.mdtable2csv.OpenTableAsCsv"
                    class="com.helgesverre.mdtable2csv.actions.OpenTableAsCsvAction"
                    text="Open in New CSV Tab"
                    description="Open this Markdown table as CSV in a new editor tab"/>
            <action id="com.helgesverre.mdtable2csv.SaveTableAsCsv"
                    class="com.helgesverre.mdtable2csv.actions.SaveTableAsCsvAction"
                    text="Save as CSV File…"
                    description="Save this Markdown table to a .csv file"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
